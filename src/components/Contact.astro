---
const infoCards = [
  { icon: 'fa-phone',        label: 'Telefone / WhatsApp', value: '(21) 2042-8680' },
  { icon: 'fa-envelope',     label: 'E-mail',              value: 'comercial@viamedmultisaude.com.br' },
  { icon: 'fa-location-dot', label: 'Localização',         value: 'Rio de Janeiro — RJ' },
];
---

<section class="sec-lg" id="contato">
  <div class="w">
    <div class="contact-grid">
      <div data-anim="left">
        <span class="eyebrow">Contato</span>
        <h2>Vamos proteger sua<br/>equipe juntos</h2>
        <p class="lead" style="margin-top:16px">Nossa equipe está pronta para criar soluções personalizadas em saúde e segurança ocupacional para a sua empresa.</p>
        <div class="cinfo-cards">
          {infoCards.map(c => (
            <div class="cinfo-card">
              <div class="cc-ic"><i class={`fa-solid ${c.icon}`}></i></div>
              <div>
                <div class="cc-label">{c.label}</div>
                <div class="cc-val">{c.value}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div data-anim="right">
      <div class="form-card">
        <h3>Envie uma mensagem</h3>
        <form id="contactForm" novalidate>
          <div class="frow">
            <div class="field"><label>Nome <span class="req">*</span></label><input class="inp" type="text" name="nome" required placeholder="Seu nome" /></div>
            <div class="field"><label>Telefone <span class="req">*</span></label><input class="inp" type="tel" name="telefone" inputmode="numeric" maxlength="14" required placeholder="(21) 00000-0000" /></div>
          </div>
          <div class="frow">
            <div class="field"><label>E-mail <span class="req">*</span></label><input class="inp" type="email" name="email" required placeholder="seu@email.com" /></div>
            <div class="field">
              <label>Assunto</label>
              <select class="sel" name="assunto">
                <option value="">Selecione...</option>
                <option>Orçamento</option>
                <option>Agendar ASO</option>
                <option>Elogio</option>
                <option>Ouvidoria</option>
                <option>Atendimento</option>
              </select>
            </div>
          </div>
          <div class="field"><label>Mensagem <span class="req">*</span></label><textarea class="txa" name="mensagem" required placeholder="Como podemos ajudar?"></textarea></div>
          <button type="submit" class="btn btn-secondary btn-lg" style="width:100%;justify-content:center">
            Enviar Mensagem <i class="fa-solid fa-paper-plane arr"></i>
          </button>
          <div class="form-ok" id="contactOk">
            <i class="fa-solid fa-circle-check" style="margin-right:8px"></i>Mensagem enviada! Responderemos em breve.
          </div>
        </form>
      </div><!-- .form-card -->
      </div><!-- data-anim wrapper -->
    </div>
  </div>
</section>

<script is:inline>
document.getElementById('contactForm')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target;
  if (!form.checkValidity()) { form.reportValidity(); return; }

  const formData = new FormData(form);
  const payload = {
    nome: formData.get('nome'),
    email: formData.get('email'),
    telefone: formData.get('telefone'),
    assunto: formData.get('assunto'),
    mensagem: formData.get('mensagem'),
  };

  try {
    const res = await fetch('https://yonnfmwlkbuoaqfkwvrg.supabase.co/functions/v1/salvar_lead', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (res.ok) {
      const ok = document.getElementById('contactOk');
      if (ok) { ok.style.display = 'block'; form.reset(); setTimeout(() => ok.style.display = 'none', 7000); }
    } else {
      alert('Erro ao enviar. Tente novamente.');
    }
  } catch (err) {
    alert('Erro na conexão. Tente novamente.');
  }
});
</script>

<style>
.contact-grid { display:grid; grid-template-columns:1fr 1.1fr; gap:72px; align-items:start }
.contact-grid h2 { font-size:clamp(28px,3vw,42px); font-weight:700; margin-bottom:16px; letter-spacing:-.5px }
.cinfo-cards { display:grid; gap:14px; margin-top:32px }
.cinfo-card { display:flex; align-items:center; gap:16px; padding:18px 20px; background:var(--g50); border-radius:var(--rxl); border:1px solid var(--g200); transition:.3s }
.cinfo-card:hover { background:#fff; border-color:var(--n200); box-shadow:var(--sh-sm) }
.cc-ic { width:48px; height:48px; border-radius:50%; background:var(--n800); color:#fff; display:grid; place-items:center; font-size:18px; flex-shrink:0; transition:.3s var(--spring) }
.cinfo-card:hover .cc-ic { transform:scale(1.1) rotate(-5deg) }
.cc-label { font-size:12px; color:var(--g400); margin-bottom:3px }
.cc-val { font-size:15px; font-weight:600; color:var(--g900) }
@media(max-width:1024px) { .contact-grid { grid-template-columns:1fr; gap:48px } }
@media(max-width:768px)  { .contact-grid { gap:36px } }
</style>
