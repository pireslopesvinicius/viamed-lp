<!-- Scroll progress bar -->
<script>
(function () {
  // ── Scroll handler único (rAF-throttled) — progress bar + header ──
  // Evita reflow forçado lendo apenas window.scrollY (barato) e cacheando a altura do documento.
  const bar = document.getElementById('progress-bar');
  const header = document.getElementById('header');
  let docHeight = document.documentElement.scrollHeight - window.innerHeight;
  window.addEventListener('resize', () => {
    docHeight = document.documentElement.scrollHeight - window.innerHeight;
  }, { passive: true });

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const y = window.scrollY;
      if (bar) bar.style.width = Math.min((y / docHeight) * 100, 100) + '%';
      header?.classList.toggle('raised', y > 10);
      ticking = false;
    });
  }, { passive: true });

  // ── Active nav link via IntersectionObserver (sem ler geometria no scroll) ──
  const ids = ['inicio','solucoes','sobre','servicos','numeros','equipe','trabalhe','contato'];
  const links = document.querySelectorAll('.nav-a');
  const navObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const id = e.target.id;
        links.forEach(l => l.classList.toggle('on', l.getAttribute('href') === '#' + id));
      }
    });
  }, { rootMargin: '-45% 0px -55% 0px' });
  ids.forEach(id => { const el = document.getElementById(id); if (el) navObs.observe(el); });

  // Mobile nav
  const mobNav = document.getElementById('mobNav');
  const ham    = document.getElementById('ham');
  const close  = document.getElementById('mobClose');
  function openNav()  { mobNav?.classList.add('open'); ham?.setAttribute('aria-expanded','true'); document.body.style.overflow='hidden'; }
  function closeNav() { mobNav?.classList.remove('open'); ham?.setAttribute('aria-expanded','false'); document.body.style.overflow=''; }
  ham?.addEventListener('click', openNav);
  close?.addEventListener('click', closeNav);
  mobNav?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeNav));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeNav(); });

  // Scroll reveal
  document.querySelectorAll('.stagger-children').forEach(parent => {
    parent.querySelectorAll('[data-anim]').forEach((child, i) => {
      if (!(child as HTMLElement).dataset.delay) (child as HTMLElement).dataset.delay = String(Math.min(i + 1, 6));
    });
  });
  const revObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const el = e.target as HTMLElement;
        el.classList.add('visible');
        revObs.unobserve(el);
        // Após a animação, remove data-anim para liberar o compositing layer
        // (transition:transform deixa box-shadow retangular em cards arredondados)
        const cleanup = () => el.removeAttribute('data-anim');
        el.addEventListener('transitionend', cleanup, { once: true });
        setTimeout(cleanup, 1400); // fallback caso transitionend não dispare
      }
    });
  }, { threshold: 0.10, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('[data-anim]').forEach(el => revObs.observe(el));

  // ── Parallax (rAF-throttled, só roda quando a imagem está visível) ──
  const pImgs = document.querySelectorAll('[data-parallax]');
  if (pImgs.length) {
    let pVisible = false;
    const pObs = new IntersectionObserver(es => { pVisible = es.some(e => e.isIntersecting); }, { rootMargin: '100px' });
    pImgs.forEach(img => { const f = (img as HTMLElement).closest('.about-frame'); if (f) pObs.observe(f); });

    let pTicking = false;
    window.addEventListener('scroll', () => {
      if (pTicking || !pVisible) return;
      pTicking = true;
      requestAnimationFrame(() => {
        const vh = window.innerHeight;
        pImgs.forEach(img => {
          const frame = (img as HTMLElement).closest('.about-frame');
          if (!frame) return;
          const rect = frame.getBoundingClientRect();        // leitura
          const factor = parseFloat((img as HTMLElement).dataset.parallax || '0.1');
          (img as HTMLElement).style.transform = `translateY(${(rect.top + rect.height / 2 - vh / 2) * factor}px)`; // escrita
        });
        pTicking = false;
      });
    }, { passive: true });
  }

  // Máscara de telefone — aplica a TODOS os inputs de telefone da página
  function formatPhone(val: string) {
    val = val.replace(/\D/g, '').slice(0, 11);
    if (val.length >= 2) val = '(' + val.slice(0, 2) + ') ' + val.slice(2);
    if (val.length >= 10) val = val.slice(0, 10) + '-' + val.slice(10);
    return val;
  }
  document.querySelectorAll('input[name="telefone"]').forEach(input => {
    input.addEventListener('keypress', (e: Event) => {
      const ke = e as KeyboardEvent;
      if (!/\d/.test(ke.key)) e.preventDefault();
    });
    input.addEventListener('input', (e: Event) => {
      const t = e.target as HTMLInputElement;
      t.value = formatPhone(t.value);
    });
  });
})();
</script>
