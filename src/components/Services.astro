---
const cards = [
  { icon: 'fa-shield-halved', title: 'Segurança e Saúde Ocupacional', desc: 'Proteção integral ao trabalhador com gestão de riscos, laudos e conformidade com as Normas Regulamentadoras.', tab: 0 },
  { icon: 'fa-anchor',        title: 'Soluções Marítimas e Offshore',  desc: 'Tecnologias e serviços para operações na indústria naval e de energia offshore com total segurança.', tab: 1 },
  { icon: 'fa-laptop-code',   title: 'Gestão de E-Social',             desc: 'Conformidade total nos eventos de SST no eSocial. Sem complexidade, sem multas, sem preocupação.', tab: 2 },
  { icon: 'fa-virus-slash',   title: 'Prevenção ao Covid-19',          desc: 'Protocolos, biossegurança e campanhas de vacinação corporativa para ambientes de trabalho seguros.', tab: 3 },
];

const panels = [
  {
    img: '/images/header-servicos01-1.webp', imgPos: '75% center', eyebrow: 'Serviço 01',
    title: 'Segurança e Saúde Ocupacional',
    desc: 'Práticas e medidas implementadas para proteger os trabalhadores contra riscos ocupacionais, promovendo um ambiente seguro, saudável e em conformidade com as NRs.',
    items: ['Elaboração e implementação de PPRA e PGR', 'Realização de exames ocupacionais (ASO)', 'PCMSO — Programa de Controle Médico', 'Treinamentos em segurança do trabalho', 'Laudos técnicos e perícias'],
  },
  {
    img: '/images/header-servicos02.webp', imgPos: '75% center', eyebrow: 'Serviço 02',
    title: 'Soluções Marítimas e Offshore',
    desc: 'Tecnologias e serviços especializados para operações no ambiente marítimo, otimizando eficiência e segurança na indústria naval e de energia offshore.',
    items: ['Gestão de saúde para plataformas offshore', 'Atendimento médico embarcado', 'Treinamentos HUET e aquáticos', 'Conformidade com normas NORMAM e Anvisa', 'Brigadas de emergência marítima'],
  },
  {
    img: '/images/section-esocial.webp', imgPos: 'center', eyebrow: 'Serviço 03',
    title: 'Gestão de E-Social',
    desc: 'Gestão completa dos eventos de SST no eSocial, garantindo conformidade e tranquilidade para a sua empresa perante o fisco e a legislação trabalhista.',
    items: ['Envio dos eventos S-2220, S-2240 e S-2210', 'Monitoramento de prazos e obrigações', 'Integração com sistemas de RH', 'Diagnóstico e adequação ao eSocial', 'Consultoria especializada contínua'],
  },
  {
    img: '/images/header-servicos04.webp', imgPos: '75% center', eyebrow: 'Serviço 04',
    title: 'Prevenção e Combate ao Covid-19',
    desc: 'Protocolos, soluções e treinamentos para garantir ambientes de trabalho seguros e em conformidade com as diretrizes do Ministério da Saúde.',
    items: ['Elaboração de protocolos sanitários', 'Testagem e rastreamento de casos', 'Campanhas de vacinação corporativa', 'Treinamento de brigadas de saúde', 'Consultoria em biossegurança'],
  },
];
---

<!-- Strip de cards -->
<section class="sec" id="solucoes">
  <div class="w">
    <div class="sh center">
      <span class="eyebrow" data-anim="up">Nossas Soluções</span>
      <h2 data-anim="up" data-delay="1">Tudo que sua empresa precisa<br/>em saúde e segurança</h2>
      <p class="lead" data-anim="up" data-delay="2">Atuamos com excelência na proteção à vida do trabalhador.</p>
    </div>
    <div class="svc-grid stagger-children">
      {cards.map(c => (
        <div class="svc-card" data-anim="scale" data-tab={c.tab}>
          <div class="svc-ic"><i class={`fa-solid ${c.icon}`}></i></div>
          <h3>{c.title}</h3>
          <p>{c.desc}</p>
          <span class="svc-more">Ver detalhes <i class="fa-solid fa-arrow-right arr"></i></span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Tabs detalhadas -->
<section class="sec-lg" id="servicos">
  <div class="w">
    <div class="sh">
      <span class="eyebrow" data-anim="up">Nossos Serviços</span>
      <h2 data-anim="up" data-delay="1">Cada solução desenhada<br/>para o seu negócio</h2>
      <p class="lead" data-anim="up" data-delay="2">Clique em cada serviço para conhecer em detalhe.</p>
    </div>
    <div class="stabs" data-anim="up" data-delay="3">
      {panels.map((p, i) => (
        <button class:list={['stab', { on: i === 0 }]} data-idx={i}>{p.title}</button>
      ))}
    </div>
    {panels.map((p, i) => (
      <div class:list={['spanel', { on: i === 0 }]} id={`sp${i}`}>
        <div class="sp-img">
          <img src={p.img} alt={p.title} width="600" height="420" loading="lazy" style={`object-position:${p.imgPos}`} />
        </div>
        <div class="sp-text">
          <span class="eyebrow">{p.eyebrow}</span>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>
          <ul class="detail-list">
            {p.items.map(item => <li>{item}</li>)}
          </ul>
          <a href="https://wa.me/552120428680" target="_blank" rel="noopener" class="btn btn-secondary btn-lg">
            <i class="fa-brands fa-whatsapp"></i> Solicitar Orçamento
          </a>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
// Card clicks → tab
document.querySelectorAll('.svc-card').forEach(card => {
  card.addEventListener('click', () => {
    const n = parseInt((card as HTMLElement).dataset.tab || '0');
    document.getElementById('servicos')?.scrollIntoView({ behavior: 'smooth' });
    setTimeout(() => switchTab(n), 500);
  });
});

// Tab buttons
document.querySelectorAll('.stab').forEach(btn => {
  btn.addEventListener('click', () => {
    const n = parseInt((btn as HTMLElement).dataset.idx || '0');
    switchTab(n);
  });
});

function switchTab(n: number) {
  document.querySelectorAll('.stab').forEach((t, i) => t.classList.toggle('on', i === n));
  document.querySelectorAll('.spanel').forEach((p, i) => p.classList.toggle('on', i === n));
}

// Dropdown links
document.querySelectorAll('[data-tab]').forEach(a => {
  a.addEventListener('click', () => {
    setTimeout(() => switchTab(parseInt((a as HTMLElement).dataset.tab || '0')), 500);
  });
});
</script>

<style>
/* ── Strip cards ── */
.svc-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:20px }
.svc-card {
  background:#fff; border:1px solid var(--g200); border-radius:var(--r2xl);
  padding:32px; transition:.4s var(--ease); cursor:pointer; position:relative; overflow:hidden;
}
.svc-card::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg,var(--n800),var(--n700));
  opacity:0; transition:.4s var(--ease);
}
.svc-card:hover { border-color:var(--n800); transform:translateY(-8px); box-shadow:var(--sh-lg) }
.svc-card:hover::before { opacity:1 }
.svc-ic {
  width:56px; height:56px; border-radius:var(--rlg); background:var(--n50); color:var(--n800);
  display:grid; place-items:center; font-size:23px; margin-bottom:20px;
  transition:.35s var(--spring); position:relative; z-index:1;
}
.svc-card:hover .svc-ic { background:rgba(255,255,255,.15); color:#fff; transform:scale(1.15) rotate(-8deg) }
.svc-card h3 { font-size:16.5px; font-weight:600; margin-bottom:10px; transition:.3s; position:relative; z-index:1 }
.svc-card p  { font-size:13.5px; line-height:1.65; color:var(--g500); margin-bottom:20px; transition:.3s; position:relative; z-index:1 }
.svc-card:hover h3,.svc-card:hover p { color:rgba(255,255,255,.9) }
.svc-more { display:inline-flex; align-items:center; gap:8px; font-size:13px; font-weight:600; color:var(--o500); transition:.3s; position:relative; z-index:1 }
.svc-card:hover .svc-more { color:var(--o400) }
.svc-more i { transition:transform .3s var(--ease) }
.svc-card:hover .svc-more i { transform:translateX(6px) }

/* ── Tabs ── */
.stabs { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:48px }
.stab {
  padding:11px 20px; border-radius:var(--rlg);
  font-family:var(--fh); font-size:13.5px; font-weight:500;
  border:1.5px solid var(--g200); background:#fff; color:var(--g600);
  cursor:pointer; transition:.25s var(--ease);
  text-align:center; line-height:1.4;
}
.stab:hover { border-color:var(--g400); color:var(--g900) }
.stab.on { background:var(--n800); color:#fff; border-color:var(--n800); box-shadow:0 8px 22px rgba(0,17,103,.20) }
.spanel { display:none; grid-template-columns:1fr 1fr; gap:64px; align-items:center }
.spanel.on { display:grid; animation:fadeUp .4s var(--ease) both }
.sp-img { border-radius:var(--r3xl); overflow:hidden; box-shadow:var(--sh-lg) }
.sp-img img { width:100%; height:420px; object-fit:cover; transition:transform .6s }
.sp-img:hover img { transform:scale(1.04) }
.sp-text h3 { font-size:clamp(22px,3vw,36px); font-weight:700; margin-bottom:16px; letter-spacing:-.5px }
.sp-text > p { font-size:15.5px; line-height:1.82; color:var(--g500); margin-bottom:24px }
.detail-list { display:grid; gap:11px; margin-bottom:32px }
.detail-list li { display:flex; align-items:center; gap:12px; font-size:15px; color:var(--g700) }
.detail-list li::before { content:''; width:8px; height:8px; border-radius:50%; background:var(--o500); flex-shrink:0 }

@media(max-width:1024px) {
  .svc-grid { grid-template-columns:repeat(2,1fr) }
  .spanel.on { grid-template-columns:1fr; gap:28px }
  .sp-img img { height:280px }
}
@media(max-width:768px) {
  .svc-grid { grid-template-columns:1fr }
  .stabs { grid-template-columns:1fr 1fr; gap:8px }
  .stab { padding:9px 14px; font-size:13px }
  .sp-img img { height:220px }
  .sp-text h3 { font-size:22px }
}
</style>
